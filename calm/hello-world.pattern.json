{
  "$schema": "https://calm.finos.org/release/1.0-rc2/meta/calm.json",
  "$id": "https://example.com/calm/hello-world.pattern.json",
  "type": "object",
  "title": "Hello World Web API Pattern",
  "description": "A minimal pattern for a Hello World web API with MISP threat intelligence validation.",
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "$ref": "https://calm.finos.org/release/1.0-rc2/meta/core.json#/defs/node",
          "type": "object",
          "properties": {
            "unique-id": { "const": "web-browser" },
            "name": { "const": "Web Browser" },
            "description": { "const": "Client browser accessing the Hello World API" },
            "node-type": { "const": "webclient" }
          }
        },
        {
          "$ref": "https://calm.finos.org/release/1.0-rc2/meta/core.json#/defs/node",
          "type": "object",
          "properties": {
            "unique-id": { "const": "hello-world-service" },
            "name": { "const": "Hello World Service" },
            "description": { "const": "A simple Hello World web API" },
            "node-type": { "const": "service" },
            "interfaces": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "prefixItems": [
                {
                  "$ref": "https://calm.finos.org/release/1.0-rc1/meta/interface.json#/defs/host-port-interface",
                  "properties": {
                    "unique-id": { "const": "service-host-port" }
                  }
                }
              ]
            },
            "controls": {
              "$ref": "https://calm.finos.org/release/1.0-rc2/meta/control.json#/defs/controls",
              "properties": {
                "threat-intelligence": {
                  "type": "object",
                  "properties": {
                    "description": {
                      "const": "MISP threat intelligence check on service endpoints"
                    },
                    "requirements": {
                      "type": "array",
                      "minItems": 1,
                      "maxItems": 1,
                      "prefixItems": [
                        {
                          "$ref": "https://calm.finos.org/release/1.0-rc2/meta/control.json#/defs/control-detail",
                          "properties": {
                            "requirement-url": {
                              "const": "https://example.com/calm/controls/misp-threat-check.requirement.json"
                            },
                            "config-url": {
                              "const": "https://example.com/calm/controls/misp-threat-check.config.json"
                            }
                          }
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "relationships": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "prefixItems": [
        {
          "$ref": "https://calm.finos.org/release/1.0-rc2/meta/core.json#/defs/relationship",
          "type": "object",
          "properties": {
            "unique-id": { "const": "browser-service" },
            "description": { "const": "Browser calls Hello World API over HTTP" },
            "protocol": { "const": "HTTP" },
            "relationship-type": {
              "const": {
                "connects": {
                  "source": { "node": "web-browser" },
                  "destination": { "node": "hello-world-service" }
                }
              }
            },
            "controls": {
              "$ref": "https://calm.finos.org/release/1.0-rc2/meta/control.json#/defs/controls",
              "properties": {
                "security": {
                  "type": "object",
                  "properties": {
                    "description": { "const": "Permitted connection security control" },
                    "requirements": {
                      "type": "array",
                      "minItems": 1,
                      "maxItems": 1,
                      "prefixItems": [
                        {
                          "$ref": "https://calm.finos.org/release/1.0-rc2/meta/control.json#/defs/control-detail",
                          "properties": {
                            "requirement-url": {
                              "const": "https://calm.finos.org/getting-started/controls/permitted-connection.requirement.json"
                            },
                            "config-url": {
                              "const": "https://calm.finos.org/getting-started/controls/permitted-connection-http.config.json"
                            }
                          }
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "required": ["description"]
        }
      ]
    }
  },
  "required": ["nodes", "relationships"]
}
